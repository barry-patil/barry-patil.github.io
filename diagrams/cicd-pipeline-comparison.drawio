        <mxCell id="40" value="Benchmark Results (same Go microservice, 3 runs avg)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#555;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;" vertex="1" parent="1">
