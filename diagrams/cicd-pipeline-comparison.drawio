<mxfile host="app.diagrams.net">
  <diagram name="CI/CD Pipeline Comparison">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="2" value="CI/CD Pipeline Comparison — GitHub Actions vs Jenkins vs GitLab CI" style="text;html=1;align=center;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="1100" height="30" as="geometry"/>
        </mxCell>

        <!-- Shared stages label -->
        <mxCell id="3" value="Same pipeline stages — different tooling" style="text;html=1;align=center;fontSize=12;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#666;" vertex="1" parent="1">
          <mxGeometry x="500" y="55" width="600" height="25" as="geometry"/>
        </mxCell>

        <!-- GitHub Actions column -->
        <mxCell id="10" value="GitHub Actions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2088FF;fontColor=#ffffff;strokeColor=#1a6fcc;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="420" height="55" as="geometry"/>
        </mxCell>

        <mxCell id="11" value="Trigger: push / PR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4ff;strokeColor=#2088FF;fontSize=11;" vertex="1" parent="1">
