        </mxCell>
        <mxCell id="21b" value="OWASP Dependency&#xa;Check" style="text;html=1;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="690" y="215" width="140" height="30" as="geometry"/>
