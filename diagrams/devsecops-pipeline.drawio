        <!-- Stage 3: Container Scan -->
        <mxCell id="22" value="Stage 3&#xa;Container Scan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="160" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="22b" value="Trivy&#xa;(CVE scanning)" style="text;html=1;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="860" y="215" width="130" height="30" as="geometry"/>
        </mxCell>

        <!-- Stage 4: Quality Gate -->
        <mxCell id="23" value="Stage 4&#xa;Quality Gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1030" y="160" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="23b" value="SonarQube&#xa;(Code Quality)" style="text;html=1;align=center;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1030" y="215" width="130" height="30" as="geometry"/>
        </mxCell>

        <!-- Docker Build -->
        <mxCell id="30" value="Docker Build&#xa;+ Push to ECR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="370" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Helm Deploy -->
        <mxCell id="31" value="Helm Deploy&#xa;(kubectl apply)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
