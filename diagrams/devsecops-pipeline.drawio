        </mxCell>

        <!-- Stage 2: SCA -->
        <mxCell id="21" value="Stage 2&#xa;SCA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
