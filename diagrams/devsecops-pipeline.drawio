        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#555;strokeWidth=2;" edge="1" source="10" target="11" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#2088FF;strokeWidth=2;" edge="1" source="11" target="12" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
