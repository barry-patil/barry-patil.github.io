<mxfile host="app.diagrams.net">
  <diagram name="Serverless AWS App">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1500" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="2" value="Serverless AWS Application — API Gateway + Lambda + DynamoDB" style="text;html=1;align=center;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="1000" height="30" as="geometry"/>
        </mxCell>

        <!-- Client -->
        <mxCell id="10" value="Client" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#232F3E;fontColor=#ffffff;strokeColor=#555;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- CloudFront -->
        <mxCell id="11" value="CloudFront CDN&#xa;(static assets)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#8C4FFF;fontColor=#ffffff;strokeColor=#6a3bbf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="220" width="160" height="55" as="geometry"/>
        </mxCell>

        <!-- S3 -->
        <mxCell id="12" value="S3&#xa;(Frontend Build)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3F8624;fontColor=#ffffff;strokeColor=#2a5c18;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="130" width="160" height="55" as="geometry"/>
        </mxCell>

        <!-- Cognito -->
        <mxCell id="13" value="Cognito User Pool&#xa;JWT auth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BF0816;fontColor=#ffffff;strokeColor=#8a060f;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="480" width="160" height="55" as="geometry"/>
        </mxCell>

        <!-- API Gateway -->
        <mxCell id="20" value="API Gateway&#xa;REST API (v1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7157B;fontColor=#ffffff;strokeColor=#a00d54;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="340" width="200" height="55" as="geometry"/>
        </mxCell>

        <!-- Lambda functions -->
        <mxCell id="30" value="Lambda Functions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#ED7100;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="140" width="360" height="430" as="geometry"/>
        </mxCell>

        <mxCell id="31" value="listItems()&#xa;GET /items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e8;strokeColor=#ED7100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="190" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="32" value="createItem()&#xa;POST /items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e8;strokeColor=#ED7100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="910" y="190" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="33" value="deleteItem()&#xa;DELETE /items/:id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e8;strokeColor=#ED7100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="280" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="34" value="processEvent()&#xa;SQS triggered (async)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e8;strokeColor=#ED7100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="910" y="280" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="35" value="authorizer()&#xa;Cognito JWT validator" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2e8;strokeColor=#ED7100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="480" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- DynamoDB -->
        <mxCell id="40" value="DynamoDB&#xa;items table (on-demand)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C7131F;fontColor=#ffffff;strokeColor=#8a0d14;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1160" y="200" width="200" height="60" as="geometry"/>
        </mxCell>

        <!-- SQS -->
        <mxCell id="41" value="SQS Queue&#xa;(async event bus)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7157B;fontColor=#ffffff;strokeColor=#a00d54;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="310" width="200" height="55" as="geometry"/>
        </mxCell>

        <!-- CloudWatch -->
        <mxCell id="42" value="CloudWatch Logs&#xa;+ X-Ray Tracing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E7157B;fontColor=#ffffff;strokeColor=#a00d54;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="420" width="200" height="55" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#555;strokeWidth=2;" edge="1" source="10" target="20" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#8C4FFF;strokeWidth=1.5;" edge="1" source="10" target="11" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#3F8624;strokeWidth=1.5;" edge="1" source="11" target="12" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="JWT" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#BF0816;strokeWidth=1.5;fontSize=9;" edge="1" source="13" target="20" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#ED7100;strokeWidth=2;" edge="1" source="20" target="30" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#C7131F;strokeWidth=2;" edge="1" source="31" target="40" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#C7131F;strokeWidth=2;" edge="1" source="32" target="40" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E7157B;strokeWidth=1.5;" edge="1" source="32" target="41" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E7157B;strokeWidth=1.5;" edge="1" source="41" target="34" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#E7157B;strokeWidth=1.5;dashed=1;" edge="1" source="30" target="42" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
