        <mxCell id="10" value="METRICS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ff7300;fontColor=#ffffff;strokeColor=#cc5a00;fontSize=13;fontStyle=1;" vertex="1" parent="1">
