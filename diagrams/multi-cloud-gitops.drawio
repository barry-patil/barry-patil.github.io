        <mxCell id="34" value="ArgoCD sync status&#xa;Healthy / Synced / OutOfSync" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="620" width="210" height="50" as="geometry"/>
