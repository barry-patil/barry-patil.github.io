        <!-- GCP GKE Cluster -->
        <mxCell id="40" value="GCP — GKE Production" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#4285F4;strokeWidth=2;verticalAlign=top;fontSize=12;fontStyle=1;" vertex="1" parent="1">
