        <mxCell id="41" value="App Workloads&#xa;(Kustomize overlays)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#4285F4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="870" y="530" width="180" height="50" as="geometry"/>
