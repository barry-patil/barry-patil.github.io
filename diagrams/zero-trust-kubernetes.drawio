<mxfile host="app.diagrams.net">
  <diagram name="Zero Trust Kubernetes">
    <mxGraphModel dx="1200" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>

        <mxCell id="2" value="Zero Trust Kubernetes — Default Deny Everything" style="text;html=1;align=center;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="800" height="30" as="geometry"/>
        </mxCell>

        <!-- Kubernetes Cluster boundary -->
        <mxCell id="3" value="Kubernetes Cluster" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;strokeWidth=2;verticalAlign=top;fontSize=13;fontStyle=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="60" width="1280" height="800" as="geometry"/>
        </mxCell>

        <!-- Cilium layer -->
        <mxCell id="10" value="Cilium CNI — eBPF Network Policy Enforcement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="100" width="440" height="50" as="geometry"/>
        </mxCell>

        <!-- SPIFFE/SPIRE -->
        <mxCell id="11" value="SPIRE Server&#xa;(Workload Identity)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="12" value="SPIRE Agent&#xa;(per node — attests workloads)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="200" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- WireGuard -->
        <mxCell id="13" value="WireGuard&#xa;Node-to-Node Encryption" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="310" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- mTLS between workloads -->
        <mxCell id="14" value="mTLS (mutual TLS)&#xa;All pod-to-pod traffic encrypted" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="360" y="310" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- Namespace: frontend -->
        <mxCell id="20" value="Namespace: frontend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;strokeWidth=1.5;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="100" width="280" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="21" value="frontend-pod&#xa;SVID: spiffe://cluster/frontend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="710" y="150" width="220" height="60" as="geometry"/>
        </mxCell>

        <!-- Namespace: backend -->
        <mxCell id="22" value="Namespace: backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;strokeWidth=1.5;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="100" width="290" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="23" value="backend-pod&#xa;SVID: spiffe://cluster/backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1025" y="150" width="240" height="60" as="geometry"/>
        </mxCell>

        <!-- CiliumNetworkPolicy -->
        <mxCell id="30" value="CiliumNetworkPolicy&#xa;frontend → backend:8080 ALLOW&#xa;Everything else: DENY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="360" width="280" height="70" as="geometry"/>
        </mxCell>

        <!-- OPA / Kyverno -->
        <mxCell id="31" value="Kyverno&#xa;Admission Controller&#xa;(enforce pod security policies)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="360" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- Vault for secrets -->
        <mxCell id="32" value="HashiCorp Vault&#xa;Secrets injected via sidecar&#xa;(no env-var secrets)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="490" width="240" height="70" as="geometry"/>
        </mxCell>

        <!-- Audit logging -->
        <mxCell id="33" value="K8s Audit Logs&#xa;→ Elasticsearch&#xa;(all API calls recorded)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="490" width="200" height="70" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=2;dashed=1;" edge="1" source="11" target="12" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="issues SVID" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#6c8ebf;strokeWidth=1.5;fontSize=9;" edge="1" source="11" target="21" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="issues SVID" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=1.5;fontSize=9;" edge="1" source="11" target="23" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="mTLS allowed" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;strokeWidth=2;fontSize=9;" edge="1" source="21" target="23" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;strokeWidth=1.5;dashed=1;" edge="1" source="10" target="30" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;strokeWidth=1.5;dashed=1;" edge="1" source="32" target="21" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#9673a6;strokeWidth=1.5;dashed=1;" edge="1" source="32" target="23" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
